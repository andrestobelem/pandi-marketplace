{
  "name": "pandi-launchpad",
  "version": "0.1.0",
  "description": "MCP server que convierte un Novation Launchpad X en un canal de luces + botones para que Claude te avise cosas y te pregunte, apretando pads.",
  "author": { "name": "Andrés Tobelem" },
  "keywords": ["midi", "launchpad", "novation", "hardware", "notifications"],
  "mcpServers": {
    "pandi-launchpad": {
      "command": "uvx",
      "args": ["--from", "${CLAUDE_PLUGIN_ROOT}", "pandi-launchpad"],
      "env": {
        "LAUNCHPAD_OUTPUT_PORT": "${LAUNCHPAD_OUTPUT_PORT}",
        "LAUNCHPAD_INPUT_PORT": "${LAUNCHPAD_INPUT_PORT}"
      }
    }
  }
}
